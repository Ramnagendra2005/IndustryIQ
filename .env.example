# ==========================================================================
# IndustryIQ configuration
# Copy this file to `.env` and fill in your own Anthropic API key.
# --------------------------------------------------------------------------
# Get a key at https://console.anthropic.com  (format: sk-ant-...)
# The key used by the Claude Code CLI does NOT work here — you need your own.
# ==========================================================================

# Leave blank to run in fully-offline SEED mode (deterministic, no API calls).
# Set it to enable live document ingestion + live copilot answers.
ANTHROPIC_API_KEY=

# LLM_MODE: "auto" (live if key present, else seed) | "live" | "seed"
LLM_MODE=auto

# Models (any valid Claude model id). Extraction runs many calls, so it
# defaults to a faster/cheaper tier; answering defaults to a stronger model.
IIQ_ANSWER_MODEL=claude-sonnet-5
IIQ_EXTRACT_MODEL=claude-sonnet-5
IIQ_VISION_MODEL=claude-sonnet-5

# Server
IIQ_HOST=0.0.0.0
IIQ_PORT=8000
