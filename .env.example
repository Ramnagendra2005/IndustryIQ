# ==========================================================================
# IndustryIQ configuration
# Copy this file to `.env` and fill in your own Google Gemini API key.
# --------------------------------------------------------------------------
# Get a key at https://aistudio.google.com/apikey  (format: AIza...)
# ==========================================================================

# Leave blank to run in fully-offline SEED mode (deterministic, no API calls).
# Set it to enable live document ingestion + live copilot answers.
GEMINI_API_KEY=

# LLM_MODE: "auto" (live if key present, else seed) | "live" | "seed"
LLM_MODE=auto

# Models (any valid Gemini model id). Extraction runs many calls, so it
# defaults to a faster/cheaper tier; answering defaults to a stronger model.
IIQ_ANSWER_MODEL=gemini-2.5-flash
IIQ_EXTRACT_MODEL=gemini-2.5-flash
IIQ_VISION_MODEL=gemini-2.5-flash

# Server
IIQ_HOST=0.0.0.0
IIQ_PORT=8000
