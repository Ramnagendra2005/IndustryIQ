# ── LLM ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>
LLM_MODE=auto                        # auto | live | seed  (auto = live when a key is present)
IIQ_ANSWER_MODEL=gemini-2.5-flash
IIQ_EXTRACT_MODEL=gemini-2.5-flash
IIQ_VISION_MODEL=gemini-2.5-flash

# ── Embeddings ────────────────────────────────────────────────────────────────
IIQ_EMBED_PROVIDER=auto              # auto | live | static
IIQ_GEMINI_EMBED_MODEL=gemini-embedding-001
IIQ_EMBED_DIM=768

# ── Supabase (persistence) ────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service-role-or-anon-key>
PERSIST_MODE=auto                    # auto | supabase | memory  (auto = supabase when URL+key present)

# ── Auth ──────────────────────────────────────────────────────────────────────
IIQ_SECRET=<random-hex-32-chars>     # e.g. python -c "import secrets;print(secrets.token_hex(32))"
IIQ_TOKEN_TTL=604800                 # seconds (7 days)

# ── Server ────────────────────────────────────────────────────────────────────
IIQ_HOST=0.0.0.0
IIQ_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173   # comma-separated; set to your deployed frontend origin(s)
